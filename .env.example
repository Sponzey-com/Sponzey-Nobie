# SidekickSponzey — 환경변수 설정 예시
# 이 파일을 .env 로 복사한 후 값을 채우세요.
# cp .env.example .env

# ─── LLM 공급자 ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# OpenAI 호환 엔드포인트 사용 시 (예: Azure, LocalAI, Ollama)
# OPENAI_BASE_URL=https://your-endpoint/v1

# Ollama 사용 시 (로컬 LLM)
# OLLAMA_HOST=http://localhost:11434

# ─── Telegram 봇 (Phase 002) ──────────────────────────
# TELEGRAM_BOT_TOKEN=123456789:AAF...
# TELEGRAM_ALLOWED_USERS=123456789,987654321

# ─── WebUI (Phase 006) ────────────────────────────────
# SIDEKICK_WEBUI_SECRET=your-secret-here

# ─── 경로 오버라이드 ───────────────────────────────────
# SIDEKICK_STATE_DIR=/custom/path/.sidekick
# SIDEKICK_CONFIG=/custom/path/config.json5

# ─── 로그 ─────────────────────────────────────────────
# SIDEKICK_LOG_LEVEL=debug    # debug | info | warn | error
# SIDEKICK_NO_COLOR=1
